POSTGRES_USER=herbarium
POSTGRES_PASSWORD=herbarium_pass
POSTGRES_DB=herbarium

# Used by Airflow providers (PostgresHook) for application ETL.
AIRFLOW_CONN_POSTGRES_DEFAULT=postgresql+psycopg2://${POSTGRES_USER}:${POSTGRES_PASSWORD}@postgres-db:5432/${POSTGRES_DB}

# Used by Airflow itself for its metadata database connection.
AIRFLOW__DATABASE__SQL_ALCHEMY_CONN=${AIRFLOW_CONN_POSTGRES_DEFAULT}

AIRFLOW_FERNET_KEY=Z9NPhNx7QR51_9p-LNHRQRXbO5owlXBJ6VUhesxA9ug=
AIRFLOW_WEBSERVER_SECRET_KEY=f59beea20b2f05a00652cd2fcf3076fd

AIRFLOW_USERNAME=admin
AIRFLOW_PASSWORD=admin_pass
AIRFLOW_FIRSTNAME=Airflow
AIRFLOW_LASTNAME=Admin
AIRFLOW_EMAIL=admin@example.com

# Optional tuning knobs (defaults are in the DAG).
HERBARIUM_DTL_BATCH_SIZE=1000
HERBARIUM_IMAGE_WORKERS=2
HERBARIUM_MAX_SOURCE_PIXELS=160000000
HERBARIUM_IMAGES_ORIGINAL_DIR=/images_data/original
HERBARIUM_IMAGES_ICON_DIR=/images_data/icons
HERBARIUM_IMAGES_LABEL_DIR=/images_data/labels

# Label crop: normalized box [ymin,xmin,ymax,xmax] on 0–1000 scale (LWG English block).
HERBARIUM_LABEL_BBOX_NORM=615,583,1000,1000
# Optional per-file overrides: JSON with basename keys and optional "default".
# HERBARIUM_LABEL_BBOX_MAP_JSON=/images_data/label_bboxes.json
# Legacy bottom strip: HERBARIUM_LABEL_CROP_MODE=bottom_ratio
